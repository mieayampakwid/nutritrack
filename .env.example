VITE_SUPABASE_URL=<YOUR_SUPABASE_URL>
VITE_SUPABASE_ANON_KEY=<YOUR_SUPABASE_ANON_KEY>

# Opsional: IP LAN Mac untuk HMR bila akses dari HP gagal (VPN / beberapa interface).
# Hanya dibaca oleh vite.config.js (bukan prefix VITE_ agar tidak ke client).
# Contoh: DEV_HMR_HOST=192.168.1.10
# DEV_HMR_HOST=

# OpenAI: hanya di server. Jangan gunakan VITE_OPENAI_*.
# Produksi:
#   supabase secrets set OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
#   supabase secrets set OPENAI_MODEL=gpt-4o-mini
#   supabase secrets set ALLOWED_ORIGIN=https://<production-domain>
# Deploy function: supabase functions deploy estimate-calories
# Lokal: isi supabase/.env.local (OPENAI_API_KEY, opsional OPENAI_MODEL), lalu:
#   supabase functions serve estimate-calories --env-file supabase/.env.local
